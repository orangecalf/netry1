# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret

# Database (optional, defaults to ./data/contacts.db)
# DB_PATH=/path/to/your/contacts.db

# SMTP for email reminders (optional — app works without this, reminders are logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Contact Manager <your-email@gmail.com>

# For Gmail: use an App Password (not your regular password)
# https://myaccount.google.com/apppasswords

# Dev: allow Vite dev server
CLIENT_ORIGIN=http://localhost:5173
